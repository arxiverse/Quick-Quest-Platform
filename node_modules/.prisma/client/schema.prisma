generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String    @db.VarChar(36)
  email         String    @db.VarChar(40)
  username      String    @db.VarChar(32)
  phone         Decimal   @db.Decimal(16, 0)
  fullname      String    @db.VarChar(84)
  birthdate     DateTime  @db.Date
  province      String    @db.VarChar(64)
  city          String    @db.VarChar(64)
  district      String    @db.VarChar(64)
  sub_district  String    @db.VarChar(64)
  full_address  String    @db.Text
  tags_skill    String?   @db.Text
  authorization String    @default("user") @db.VarChar(24)
  created_at    DateTime? @db.Date
  updated_at    DateTime? @db.Date

  @@id([id, email, username, phone])
  @@map("user_identification")
}

model Auth {
  id            String    @db.VarChar(36)
  username      String    @db.VarChar(36)
  email         String    @db.VarChar(64)
  phone         Decimal   @db.Decimal(16, 0)
  password      String    @db.VarChar(124)
  authorization String    @default("user") @db.VarChar(24)
  auth_token    String    @db.VarChar(255)
  created_at    DateTime? @db.Date
  updated_at    DateTime? @db.Date

  @@id([id, username, email, phone])
  @@map("authentication")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  phone         String   @unique
  fullname      String
  birthdate     DateTime
  province      String
  city          String
  district      String
  sub_district  String
  full_address  String   @db.Text
  tags_skills   String   @db.Text
  authorization String   @default("user")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  auth          Auth?

  @@map("user_identification")
}

model Auth {
  id            String   @id @default(uuid())
  user_id       String   @unique
  email         String   @unique
  username      String   @unique
  phone         String   @unique
  authorization String   @default("user")
  password      String   @db.Text
  auth_token    String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("authentication")
}
